{
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "target": "esnext",
    "module": "esnext",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "paths": {
      "@packages/*": ["./packages/*"]
    }
  },
  "include": [
    "packages/**/*"
  ],
  "exclude": [
    "packages/types/types/*"
  ]
}
