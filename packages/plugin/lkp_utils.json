{
  "$schema": "node_modules/@latedream/moekoe-plugin-utils/schema/lkp_utils.json",
  "manifest": {
    "outpath": "dist/manifest.json"
  },
  "meta": {
    "id": "latelib",
    "permissions": ["scripting"],
    "injects": [
      {
        "matches": ["<all_urls>"],
        "js": ["lib.iife.js"],
        "run_at": "document_start",
        "world": "MAIN"
      }
    ],
    "popup": {
      "html": "popup.html",
      "icon": "icon.png",
      "title": "popup"
    },
    "icons": {
      "128": "icon.png"
    }
  }
}
