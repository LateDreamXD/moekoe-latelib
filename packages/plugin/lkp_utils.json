{
  "$schema": "node_modules/@latedream/moekoe-plugin-utils/schema/lkp_utils.json",
  "manifest": {
    "outpath": "dist/manifest.json"
  },
  "meta": {
    "id": "late-lib",
    "permissions": ["scripting"],
    "injects": [
      {
        "matches": [
          "http://localhost:8080/*",
          "https://app.testnet.music.moekoe.cn/*",
          "file:///*"
        ],
        "js": ["lib.iife.js"],
        "run_at": "document_start",
        "world": "MAIN"
      }
    ],
    "icons": {
      "128": "icon.png"
    }
  }
}
